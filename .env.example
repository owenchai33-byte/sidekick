# ─────────────────────────────────────────────────────────────
# SideKick environment
# Copy this file to `.env.local` and fill in a key. Never commit .env.local.
# Without a key the app still runs in DEMO MODE (labelled sample copy).
# ─────────────────────────────────────────────────────────────

# Which provider to use for the content engine: "gemini" (free) or "claude".
AI_PROVIDER=gemini

# Google AI Studio key — FREE tier. Get one at https://aistudio.google.com/apikey
# Used when AI_PROVIDER=gemini
GEMINI_API_KEY=

# Anthropic key — pay-per-use. Get one at https://console.anthropic.com/
# Used when AI_PROVIDER=claude. Leave blank until TRR approves and revenue covers it.
ANTHROPIC_API_KEY=

# Optional model overrides (sensible defaults are used if unset)
# GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_MODEL=claude-sonnet-5
